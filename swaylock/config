# swaylock config — gruvbox-dark palette

# Effects (swaylock-effects)
screenshots
effect-blur=7x5
fade-in=0.4
clock
timestr=%H:%M:%S
datestr=%a, %b %d

# Background
color=1d2021

# Ring / indicator
ring-color=ea6962
key-hl-color=b8bb26
line-color=1d2021
inside-color=1d2021
separator-color=00000000

# Text
text-color=d4be98
font=NotoSans Nerd Font

# Indicator
indicator-radius=120
indicator-thickness=10
line-uses-inside

# Success
ring-ver-color=b8bb26
inside-ver-color=1d2021
line-ver-color=1d2021
text-ver-color=d4be98

# Wrong
ring-wrong-color=ea6962
inside-wrong-color=1d2021
line-wrong-color=1d2021
text-wrong-color=d4be98

# Hide cursor while locked
hide-keyboard-layout
