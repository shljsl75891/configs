# configure yabai scripting addition
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

# bsp / stack / float
yabai -m config layout bsp;
yabai -m config window_placement second_child;

# beautiful gaps
yabai -m config top_padding 5;
yabai -m config bottom_padding 5;
yabai -m config left_padding 5;
yabai -m config right_padding 5;
yabai -m config window_gap 5;

# mouse autofocus on focused window - need to check this on dual monitor setup
# yabai -m config mouse_follows_focus on;

# Moving or Resizing windows
yabai -m config mouse_modifier alt;
yabai -m config mouse_action1 move;
yabai -m config mouse_action2 resize;

# Disable tiling window management for following apps
yabai -m rule --add app="^System Settings$" manage=off;
yabai -m rule --add app="^Finder$" manage=off;
yabai -m rule --add app="^Calculator$" manage=off;

# beautiful gaps
yabai -m config top_padding    10
yabai -m config bottom_padding 10
yabai -m config left_padding   10
yabai -m config right_padding  10
yabai -m config window_gap     10

# disable window shadows
yabai -m config window_shadow off

# enable window opacity 
yabai -m config window_opacity on
yabai -m config active_window_opacity 0.9
yabai -m config normal_window_opacity 0.9

borders active_color=0xff8ec07c inactive_color=0xff665c54 width=3.0 &
