{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "zai-coding-plan/glm-5.1",
  "small_model": "openrouter/openai/gpt-oss-20b",
  "permission": "allow",
  "agent": { "explore": { "model": "zai-coding-plan/glm-5.1" } },
  "provider": {
    "ollama": {
      "models": {
        "glm-5.1:cloud": {
          "_launch": true,
          "limit": {
            "context": 202752,
            "output": 131072,
          },
          "name": "glm-5.1:cloud",
        },
        "kimi-k2.5:cloud": {
          "_launch": true,
          "limit": {
            "context": 262144,
            "output": 262144,
          },
          "name": "kimi-k2.5:cloud",
        },
        "minimax-m2.7:cloud": {
          "_launch": true,
          "limit": {
            "context": 204800,
            "output": 128000,
          },
          "name": "minimax-m2.7:cloud",
        },
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1",
      },
    },
  },
  "mcp": {
    "Ref": {
      "type": "local",
      "command": ["bunx", "ref-tools-mcp@latest"],
      "enabled": false,
      "environment": {
        "REF_API_KEY": "{env:REF_API_KEY}",
      },
    },
  },
}
