{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "default_agent": "plan",
  "subagent_depth": 4,
  "provider": {
    "opencode": {
      "options": {
        "headers": {
          "sleeve-provider": "opencode",
          "sleeve-harness": "opencode",
        },
        "baseURL": "http://127.0.0.1:17321",
      },
    },
    "anthropic": {
      "options": {
        "headers": {
          "sleeve-provider": "anthropic",
          "sleeve-harness": "opencode",
        },
        "baseURL": "http://127.0.0.1:17321",
      },
    },
  },
  "model": "anthropic/claude-sonnet-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "permission": {
    "external_directory": "allow",
    "edit": {
      "*": "allow",
      "*.env": "deny",
      "*.env.defaults": "ask",
      "*.env.example": "ask",
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.defaults": "allow",
      "*.env.example": "allow",
    },
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "rmdir *": "ask",
      "git restore *": "deny",
      "git stash *": "ask",
      "git clean *": "ask",
      "HUSKY=0 git commit *": "ask",
      "git commit *": "ask",
      "git reset *": "ask",
      "HUSKY=0 git push *": "ask",
      "git push *": "ask",
      "git -C *": "deny",
      "docker compose down *": "ask",
      "docker volume rm *": "ask",
    },
  },
  "formatter": false,
  "lsp": false,
  "share": "disabled",
  "agent": {
    "compaction": {
      "model": "anthropic/claude-sonnet-5",
      "variant": "high",
      "temperature": 0.4,
    },
    "build": { "color": "#d3869b" },
    "plan": { "permission": { "edit": "deny" }, "color": "#8ec07c" },
    "explore": { "model": "opencode/big-pickle", "color": "#b8bb26" },
    "general": { "model": "anthropic/claude-sonnet-5", "color": "#b8bb26" },
    "scout": {
      "model": "opencode/deepseek-v4-flash-free",
      "mode": "subagent",
      "color": "#d3869b",
    },
  },
  "plugin": ["@sahiljassal/opencode-anthropic-auth"],
  "compaction": { "auto": false, "prune": false, "reserved": 8000 },
  "mcp": {
    "exa": {
      "type": "local",
      "command": ["npx", "-y", "exa-mcp-server"],
      "environment": { "EXA_API_KEY": "{env:EXA_API_KEY}" },
      "enabled": false,
    },
    "Ref": {
      "type": "local",
      "command": ["npx", "ref-tools-mcp@latest"],
      "environment": { "REF_API_KEY": "{env:REF_API_KEY}" },
      "enabled": false,
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": false,
    },
  },
}
