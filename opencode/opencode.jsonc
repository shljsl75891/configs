{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "zai-coding-plan/glm-5",
  "small_model": "opencode/mimo-v2-flash-free",
  "permission": "allow",
  "mcp": {
    "Ref": {
      "type": "local",
      "command": ["bunx", "ref-tools-mcp@latest"],
      "enabled": false,
      "environment": {
        "REF_API_KEY": "{env:REF_API_KEY}",
      },
    },
  },
}
