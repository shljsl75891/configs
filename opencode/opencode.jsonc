{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "anthropic/claude-sonnet-4-6",
  "small_model": "anthropic/claude-haiku-4-5",
  "permission": "allow",
  "formatter": false,
  "lsp": false,
  "agent": {
    "compaction": {
      "model": "github-copilot/gpt-5.3-codex",
      "variant": "xhigh",
      "temperature": 0.2,
    },
    "build": { "enable1mContext": true },
    "plan": { "enable1mContext": true },
    "explore": { "model": "opencode-go/kimi-k2.6" },
  },
  "plugin": ["opencode-claude-auth@latest"],
  "compaction": { "auto": false, "prune": true, "reserved": 8000 },
  "mcp": {
    "Ref": {
      "type": "local",
      "command": ["bunx", "ref-tools-mcp@latest"],
      "environment": {
        "REF_API_KEY": "{env:REF_API_KEY}",
      },
    },
  },
}
