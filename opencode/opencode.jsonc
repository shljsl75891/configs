{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "anthropic/claude-sonnet-4-6",
  "small_model": "zai-coding-plan/glm-4.5-air",
  "permission": {
    "external_directory": "allow",
    "edit": {
      "*": "allow",
      "*.env": "deny",
      "*.env.defaults": "ask",
      "*.env.example": "ask",
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.defaults": "allow",
      "*.env.example": "allow",
    },
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "rmdir *": "ask",
      "git restore *": "deny",
      "git stash *": "ask",
      "git clean *": "ask",
      "git commit *": "ask",
      "git reset *": "ask",
      "git push *": "ask",
      "git -C *": "deny",
      "docker compose down *": "ask",
      "docker volume rm *": "ask",
    },
  },
  "formatter": false,
  "lsp": false,
  "share": "disabled",
  "agent": {
    "compaction": {
      "model": "zai-coding-plan/glm-5-turbo",
      "variant": "high",
      "temperature": 0.4,
    },
    "build": { "color": "#d3869b" },
    "plan": { "color": "#8ec07c" },
    "explore": { "model": "opencode/big-pickle", "color": "#b8bb26" },
    "general": { "model": "zai-coding-plan/glm-5.2", "color": "#b8bb26" },
    "scout": { "model": "zai-coding-plan/glm-5-turbo", "color": "#d3869b" },
  },
  "plugin": ["@sahiljassal/opencode-anthropic-auth", "@tarquinen/opencode-dcp"],
  "compaction": { "auto": false, "prune": true, "reserved": 8000 },
  "mcp": {
    "Ref": {
      "type": "local",
      "command": ["npx", "ref-tools-mcp@latest"],
      "environment": { "REF_API_KEY": "{env:REF_API_KEY}" },
      "enabled": false,
    },
    "zai-vision": {
      "type": "local",
      "command": ["npx", "-y", "@z_ai/mcp-server"],
      "timeout": 300000,
      "environment": {
        "Z_AI_API_KEY": "{env:ZAI_API_KEY}",
        "Z_AI_MODE": "ZAI",
      },
      "enabled": false,
    },
    "web-search-prime": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": { "Authorization": "Bearer {env:ZAI_API_KEY}" },
      "enabled": false,
    },
    "web-reader": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": { "Authorization": "Bearer {env:ZAI_API_KEY}" },
      "enabled": false,
    },
    "zread": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/zread/mcp",
      "headers": { "Authorization": "Bearer {env:ZAI_API_KEY}" },
      "enabled": false,
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": false,
    },
  },
}
