{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "anthropic/claude-sonnet-4-6",
  "small_model": "github-copilot/claude-haiku-4.5",
  "permission": {
    "external_directory": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.defaults": "allow",
      "*.env.example": "allow",
    },
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "rmdir *": "ask",
      "git restore*": "ask",
      "git checkout .*": "ask",
      "git checkout --*": "ask",
      "git branch -d*": "ask",
      "git branch -D*": "ask",
      "git stash*": "ask",
      "git clean*": "ask",
      "git reset --hard*": "ask",
      "git push --force*": "deny",
      "git push --force-with-lease*": "deny",
      "git push*": "ask",
      "push --force*": "deny",
      "docker compose down*": "ask",
      "docker-compose down*": "ask",
      "docker volume rm*": "ask",
      "kill*": "ask",
      "pkill*": "ask",
      "killall*": "ask",
    },
  },
  "formatter": false,
  "lsp": { "eslint": { "disabled": true }, "oxlint": { "disabled": true } },
  "agent": {
    "compaction": {
      "model": "github-copilot/gpt-5.3-codex",
      "temperature": 0.2,
    },
    "build": { "color": "#d3869b" },
    "plan": { "color": "#8ec07c" },
    "explore": { "model": "zai-coding-plan/glm-4.7", "color": "#b8bb26" },
  },
  "plugin": ["opencode-claude-auth@latest"],
  "compaction": { "auto": false, "prune": true, "reserved": 8000 },
  "mcp": {
    "Ref": {
      "type": "local",
      "command": ["npx", "ref-tools-mcp@latest"],
      "environment": { "REF_API_KEY": "{env:REF_API_KEY}" },
    },
    "zai-vision": {
      "type": "local",
      "command": ["npx", "-y", "@z_ai/mcp-server"],
      "environment": {
        "Z_AI_API_KEY": "{env:ZAI_API_KEY}",
        "Z_AI_MODE": "ZAI",
      },
      "enabled": false,
    },
    "web-search-prime": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}",
      },
    },
    "web-reader": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}",
      },
    },
    "zread": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}",
      },
    },
  },
}
